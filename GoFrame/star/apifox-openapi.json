{
  "openapi": "3.0.0",
  "info": {
    "title": "Star API",
    "description": "GoFrame Star 项目接口文档",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "用户",
      "description": "用户相关接口"
    },
    {
      "name": "单词",
      "description": "单词管理接口"
    },
    {
      "name": "Hello",
      "description": "示例接口"
    }
  ],
  "paths": {
    "/hello": {
      "get": {
        "tags": ["Hello"],
        "summary": "You first hello api",
        "operationId": "hello",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string",
                  "example": "Hello World"
                }
              }
            }
          }
        }
      }
    },
    "/users/register": {
      "post": {
        "tags": ["用户"],
        "summary": "注册",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password", "email"],
                "properties": {
                  "username": {
                    "type": "string",
                    "description": "用户名",
                    "minLength": 3,
                    "maxLength": 12,
                    "example": "testuser"
                  },
                  "password": {
                    "type": "string",
                    "description": "密码",
                    "minLength": 6,
                    "maxLength": 16,
                    "example": "123456"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "邮箱",
                    "example": "test@example.com"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "注册成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/users/login": {
      "post": {
        "tags": ["用户"],
        "summary": "登录",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": {
                    "type": "string",
                    "description": "用户名",
                    "minLength": 3,
                    "maxLength": 12,
                    "example": "testuser"
                  },
                  "password": {
                    "type": "string",
                    "description": "密码",
                    "minLength": 6,
                    "maxLength": 16,
                    "example": "123456"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": {
                          "type": "string",
                          "description": "在需要鉴权的接口中header加入Authorization: token",
                          "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "用户名或密码错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/account/info": {
      "get": {
        "tags": ["用户"],
        "summary": "获取信息",
        "operationId": "accountInfo",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "username": {
                          "type": "string",
                          "description": "用户名",
                          "example": "testuser"
                        },
                        "email": {
                          "type": "string",
                          "description": "邮箱",
                          "example": "test@example.com"
                        },
                        "created": {
                          "type": "string",
                          "format": "date-time",
                          "description": "创建时间",
                          "example": "2024-01-01T12:00:00Z"
                        },
                        "update": {
                          "type": "string",
                          "format": "date-time",
                          "description": "更新时间",
                          "example": "2024-01-01T12:00:00Z"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/words": {
      "post": {
        "tags": ["单词"],
        "summary": "创建",
        "operationId": "createWord",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["word", "definition", "example_sentence", "chinese_translation", "pronunciation", "proficiency_level"],
                "properties": {
                  "word": {
                    "type": "string",
                    "description": "单词",
                    "minLength": 1,
                    "maxLength": 100,
                    "example": "hello"
                  },
                  "definition": {
                    "type": "string",
                    "description": "单词定义",
                    "minLength": 1,
                    "maxLength": 300,
                    "example": "used as a greeting or to begin a phone conversation"
                  },
                  "example_sentence": {
                    "type": "string",
                    "description": "例句",
                    "minLength": 1,
                    "maxLength": 300,
                    "example": "Hello, how are you today?"
                  },
                  "chinese_translation": {
                    "type": "string",
                    "description": "中文翻译",
                    "minLength": 1,
                    "maxLength": 300,
                    "example": "你好，你今天怎么样？"
                  },
                  "pronunciation": {
                    "type": "string",
                    "description": "发音",
                    "minLength": 1,
                    "maxLength": 100,
                    "example": "/həˈloʊ/"
                  },
                  "proficiency_level": {
                    "type": "integer",
                    "description": "熟练度，1最低，5最高",
                    "minimum": 1,
                    "maximum": 5,
                    "example": 3
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["单词"],
        "summary": "列表",
        "operationId": "listWords",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "word",
            "in": "query",
            "description": "模糊查询单词",
            "required": false,
            "schema": {
              "type": "string",
              "maxLength": 100
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "页码，默认1",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "每页数量，默认10",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "list": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "integer",
                                "example": 1
                              },
                              "word": {
                                "type": "string",
                                "example": "hello"
                              },
                              "definition": {
                                "type": "string",
                                "example": "used as a greeting"
                              },
                              "proficiencyLevel": {
                                "type": "integer",
                                "example": 3
                              }
                            }
                          }
                        },
                        "total": {
                          "type": "integer",
                          "example": 100
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/words/{id}": {
      "get": {
        "tags": ["单词"],
        "summary": "详情",
        "operationId": "getWordDetail",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "单词ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 1
                        },
                        "word": {
                          "type": "string",
                          "example": "hello"
                        },
                        "definition": {
                          "type": "string",
                          "example": "used as a greeting or to begin a phone conversation"
                        },
                        "exampleSentence": {
                          "type": "string",
                          "example": "Hello, how are you today?"
                        },
                        "chineseTranslation": {
                          "type": "string",
                          "example": "你好，你今天怎么样？"
                        },
                        "pronunciation": {
                          "type": "string",
                          "example": "/həˈloʊ/"
                        },
                        "proficiencyLevel": {
                          "type": "integer",
                          "example": 3
                        },
                        "createdAt": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2024-01-01T12:00:00Z"
                        },
                        "updatedAt": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2024-01-01T12:00:00Z"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "单词不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["单词"],
        "summary": "更新",
        "operationId": "updateWord",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "单词ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id", "word", "definition", "example_sentence", "chinese_translation", "pronunciation", "proficiency_level"],
                "properties": {
                  "id": {
                    "type": "integer",
                    "description": "单词ID",
                    "example": 1
                  },
                  "word": {
                    "type": "string",
                    "description": "单词",
                    "minLength": 1,
                    "maxLength": 100,
                    "example": "hello"
                  },
                  "definition": {
                    "type": "string",
                    "description": "单词定义",
                    "minLength": 1,
                    "maxLength": 300,
                    "example": "used as a greeting or to begin a phone conversation"
                  },
                  "example_sentence": {
                    "type": "string",
                    "description": "例句",
                    "minLength": 1,
                    "maxLength": 300,
                    "example": "Hello, how are you today?"
                  },
                  "chinese_translation": {
                    "type": "string",
                    "description": "中文翻译",
                    "minLength": 1,
                    "maxLength": 300,
                    "example": "你好，你今天怎么样？"
                  },
                  "pronunciation": {
                    "type": "string",
                    "description": "发音",
                    "minLength": 1,
                    "maxLength": 100,
                    "example": "/həˈloʊ/"
                  },
                  "proficiency_level": {
                    "type": "integer",
                    "description": "熟练度，1最低，5最高",
                    "minimum": 1,
                    "maximum": 5,
                    "example": 4
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "单词不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["单词"],
        "summary": "删除",
        "operationId": "deleteWord",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "单词ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "删除成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "单词不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": -1
          },
          "message": {
            "type": "string",
            "example": "error message"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "在需要鉴权的接口中header加入 Authorization: Bearer {token}"
      }
    }
  }
}
